# LLM providers — set the key(s) for whichever provider your strategy's model uses.
# The provider is chosen from the model name (or StrategyConfig.provider).
GROQ_API_KEY=                 # default model (llama-3.1-8b-instant), llama-3.3-70b-versatile, etc.
OPENAI_API_KEY=              # gpt-* models
ANTHROPIC_API_KEY=          # claude-* models
GOOGLE_API_KEY=             # gemini-* models

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key  # or leave empty for in-memory

# Circle (Arc testnet) — only needed for live-mode on-chain settlement
CIRCLE_API_KEY=your-circle-api-key
CIRCLE_ENTITY_SECRET=        # required alongside CIRCLE_API_KEY
AGENT_WALLET_ID=             # set after creating a wallet to persist it across restarts
ARC_MARKET_ADDRESS=          # Arc testnet address trades settle to (defaults to a burn address)

# App
AGENT_INTERVAL_MINUTES=30
DEFAULT_BANKROLL=1000.0
KELLY_FRACTION=0.25
